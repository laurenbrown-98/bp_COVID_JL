version
suppressPackageStartupMessages({
library(tidyverse)
library(lubridate)
library(stringr)
library(purrr)
})
.args <- if(interactive()){
c("outputs/contributions_ET_noIndex.RDS",
"outputs/overall_contributions_ET.RDS",
"outputs/ZAM_index.RDS")
}else{
commandArgs(trailingOnly = TRUE)
}
include <- c("zamstar_id", "P_episode_number", "P_tb_first_evidence_date", "P_tb_last_evidence_date",
"date", "P_tb_treatment_start_date", "P_tb_treatment_status", "study_end_date")
date_map <- readRDS("outputs/date_map.RDS")
ASYMP_SYMP_ET <- readRDS(.args[2]) %>%
mutate(study_end_date = as.Date("2020-12-30")) %>%
mutate(time_to_diag = ifelse(hivcombine == 0 | is.na(hivcombine) == T, 12, 6),
date_infectious = P_tb_first_evidence_date %m-% months(time_to_diag),
post_self_cure = P_tb_first_evidence_date + years(3),
treat_end_assumed = as.Date(ifelse(P_dr_tb == 1,
ifelse(year(P_tb_treatment_start_date) >= 2017,
P_tb_treatment_start_date %m+% months(9),
P_tb_treatment_start_date %m+% months(18)),
P_tb_treatment_start_date %m+% months(6)),
origin = "1970-01-01")) %>%
select(all_of(include), "hh_symp_stat_ext6", "hh_symp_stat_WHO", "date_infectious", "post_self_cure", "treat_end_assumed")
)
)
# Load packages
library(metafor)
library(dplyr)
set.seed(2025)
# Study 1: stratified by sex and race (4 subgroups)
study1 <- data.frame(
study_id = 1,
subgroup_id = 1:4,
sample_size = c(1200, 1300, 1100, 1250),
prevalence = c(0.45, 0.50, 0.35, 0.55),
age_group = "12–18",
sex = c("male", "female", "male", "female"),
race = c("Black", "Black", "Mixed", "Mixed"),
test_type = "TST",
hiv_status = "HIV-",
method = "school survey"
)
# Study 2: stratified by age and HIV status (3 subgroups)
study2 <- data.frame(
study_id = 2,
subgroup_id = 1:3,
sample_size = c(1000, 1050, 950),
prevalence = c(0.30, 0.40, 0.35),
age_group = c("12–15", "15–18", "12–18"),
sex = NA,
race = NA,
test_type = "IGRA",
hiv_status = c("HIV-", "HIV-", "HIV+"),
method = "clinic screening"
)
# Study 3: stratified by age only (2 subgroups)
study3 <- data.frame(
study_id = 3,
subgroup_id = 1:2,
sample_size = c(1500, 1400),
prevalence = c(0.25, 0.28),
age_group = c("12–15", "15–18"),
sex = NA,
race = NA,
test_type = "TST",
hiv_status = "HIV-",
method = "school survey"
)
# Combine all studies
dat <- bind_rows(study1, study2, study3) %>%
mutate(cases = round(prevalence * sample_size))
dat
# ----- Calculate effect size (logit-prevalence) -----
dat_es <- escalc(measure = "PLO", xi = cases, ni = sample_size, data = dat)
dat_es
# ----- Fit meta-regression model clustered by study -----
model <- rma.mv(yi, vi,
mods = ~ age_group + sex + race + test_type + hiv_status + method,
random = ~ 1 | study_id,
data = dat_es)
summary(model)
# ----- Optional: predict prevalence for a hypothetical group -----
new_data <- data.frame(
age_group = "12–18",
sex = "female",
race = "Black",
test_type = "TST",
hiv_status = "HIV-",
method = "school survey"
)
predict(model, newmods = model.matrix(~ age_group + sex + race + test_type + hiv_status + method, data = new_data)[, -1])
forest(dat_es$yi, vi = dat_es$vi,
slab = paste("Study", dat_es$study_id, "-", dat_es$subgroup_id),
xlab = "Logit-transformed prevalence",
mlab = "Pooled effect",
order = dat_es$study_id)
invlogit <- function(x) exp(x) / (1 + exp(x))
# Transform effect sizes
dat_es$prev <- invlogit(dat_es$yi)
dat_es$ci.lb <- invlogit(dat_es$yi - 1.96 * sqrt(dat_es$vi))
dat_es$ci.ub <- invlogit(dat_es$yi + 1.96 * sqrt(dat_es$vi))
# Forest plot in proportion scale
forest(dat_es$prev, ci.lb = dat_es$ci.lb, ci.ub = dat_es$ci.ub,
xlab = "Prevalence (%)",
slab = paste("Study", dat_es$study_id, "-", dat_es$subgroup_id),
alim = c(0, 1),
refline = NA)
library(bpmodels)
install.packages("bpmodels")
library(tidyverse)
library(lubridate)
library(ggplot2)
## parameters
proj_window = 14
last_av_date = as.Date("2020-03-13")
nsims = 5
meanlog_si = log(4.7)
sdlog_si = log(2.9)
offspring_mean = 2
offspring_dispersion = 0.38
dd_firstcases_raw <- read.csv('https://raw.githubusercontent.com/dsfsi/covid19za/master/data/covid19za_timeline_confirmed.csv', header = TRUE)
dd_firstcases_raw
firstdate = '2020-03-05'
dd_firstcases <- (dd_firstcases_raw
%>% select(case_id, date)
%>% mutate(date = dmy(date))
%>% mutate(ts = yday(date) - yday(firstdate) + 1)
%>% filter(date <= last_av_date)
)
dd_firstcases
projection_start = max(dd_firstcases$ts)
projection_finish = projection_start + proj_window
projection_start
projection_finish
## serial interval log-normally distributed with mean = 4.7, sd = 2.9
si <- function(n){
return(rlnorm(n, meanlog = meanlog_si, sdlog = sdlog_si))
}
dd_sims <- data.frame(time = c(), cases = c(), sim = c())
for(i in 1:nsims){
## simulate a chain
tmp <- chain_sim(n = nrow(dd_firstcases), offspring = 'nbinom', mu = offspring_mean, size = offspring_dispersion, serial = si, tf = projection_finish, t0 = dd_firstcases$ts)
## print(tmp)
## create a time series
ts_tmp <- (tmp %>% mutate(time = floor(time))
%>% group_by(time)
%>% summarise(cases = n())
%>% mutate(sim = i)
)
dd_sims = rbind(dd_sims, ts_tmp)
}
## simulate a chain
tmp <- chain_sim(n = nrow(dd_firstcases), offspring = 'nbinom', mu = offspring_mean, size = offspring_dispersion, serial = si, tf = projection_finish, t0 = dd_firstcases$ts)
for(i in 1:nsims){
## simulate a chain
tmp <- chain_sim(n = nrow(dd_firstcases), offspring = 'nbinom', mu = offspring_mean, size = offspring_dispersion, serial = si, tf = projection_finish, t0 = dd_firstcases$ts)
## print(tmp)
## create a time series
ts_tmp <- (tmp %>% mutate(time = floor(time))
%>% group_by(time)
%>% summarise(cases = n())
%>% mutate(sim = i)
)
dd_sims = rbind(dd_sims, ts_tmp)
}
